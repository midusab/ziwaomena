rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isOrderOwner() {
      return isSignedIn() && resource.data.uid == request.auth.uid;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['displayName', 'email', 'role']) 
        && data.displayName is string && data.displayName.size() <= 100
        && data.email is string && data.email.size() <= 100
        && data.role in ['user', 'admin']
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (!('phone' in data) || (data.phone is string && data.phone.size() <= 20))
        && (!('address' in data) || (data.address is string && data.address.size() <= 500))
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['items', 'totalPrice', 'status', 'paymentMethod', 'uid', 'createdAt', 'customerName', 'customerPhone', 'deliveryAddress'])
        && data.items is list && data.items.size() <= 50
        && data.totalPrice is number && data.totalPrice >= 0
        && data.status in ['pending', 'processing', 'out-for-delivery', 'delivered', 'cancelled']
        && data.paymentMethod in ['mpesa', 'stripe']
        && data.uid == request.auth.uid
        && (data.customerName is string && data.customerName.size() <= 100)
        && (data.customerPhone is string && data.customerPhone.size() <= 20)
        && (data.deliveryAddress is string && data.deliveryAddress.size() <= 500)
        && (data.riderLocation == null || (data.riderLocation.lat is number && data.riderLocation.lng is number));
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false; // Only admins or specific queries
      allow create: if isOwner(userId) 
        && isValidUser(incoming()) 
        && incoming().role == 'user';
      allow update: if isOwner(userId) 
        && isValidUser(incoming())
        && incoming().role == existing().role
        && incoming().email == existing().email
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phone', 'address', 'updatedAt']);
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow get: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if isSignedIn() 
        && isValidOrder(incoming())
        && incoming().status == 'pending'
        && incoming().createdAt == request.time;
      
      allow update: if isOrderOwner()
        && (
          // Simulation actions allowed for demo purposes
          (incoming().diff(existing()).affectedKeys().hasOnly(['status', 'riderLocation']) 
           && incoming().status in ['out-for-delivery', 'delivered'])
          ||
          (incoming().diff(existing()).affectedKeys().hasOnly(['riderLocation']))
        );
    }

    // Connection test collection
    match /_connection_test/{docId} {
      allow read: if isSignedIn();
    }
  }
}
